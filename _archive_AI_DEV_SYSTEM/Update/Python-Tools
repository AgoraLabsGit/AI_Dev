        # Create task object
        task = DevelopmentTask(
            id=self.generate_task_id(),
            title=task_description,
            description="",
            tags=set(),
            files_modified=[],
            tier_references=[],
            timestamp=datetime.now(),
            ai_agent='cursor',
            status='planning'
        )
        
        # Suggest relevant tiers and tags
        suggested_tiers = self.suggest_relevant_tiers(task_description)
        suggested_tags = self.suggest_task_tags(task_description)
        
        # Log task initiation
        self.log_task_start(task, suggested_tiers, suggested_tags)
        
        # Hand off to Cursor AI
        self.handoff_to_cursor(task)
        
    def monitor_ai_progress(self):
        """Monitor AI development progress and facilitate handoffs"""
        # Check for Cursor completion signals
        if self.check_cursor_completion():
            self.handoff_to_copilot()
        
        # Check for Copilot review completion
        if self.check_copilot_completion():
            self.complete_task()
    
    def update_pattern_library(self, task: DevelopmentTask):
        """Update Tier 2 living examples with new patterns"""
        for file_path in task.files_modified:
            if self.is_reusable_pattern(file_path):
                self.extract_and_store_pattern(file_path, task.tags)

class FileWatcher(FileSystemEventHandler):
    """Watches for file changes and updates hashtag index"""
    
    def __init__(self, hashtag_manager: HashtagManager):
        self.hashtag_manager = hashtag_manager
    
    def on_modified(self, event):
        if not event.is_directory:
            file_path = Path(event.src_path)
            if self.should_process_file(file_path):
                self.process_file_change(file_path)
    
    def process_file_change(self, file_path: Path):
        """Process file changes and update tags"""
        with open(file_path, 'r') as f:
            content = f.read()
        
        suggested_tags = self.hashtag_manager.suggest_tags(file_path, content)
        print(f"📝 File modified: {file_path}")
        print(f"🏷️  Suggested tags: {', '.join(suggested_tags)}")

def main():
    """Main CLI for AI-First Development System"""
    import argparse
    
    parser = argparse.ArgumentParser(description='AI-First Development System Tools')
    parser.add_argument('command', choices=['setup', 'migrate', 'monitor', 'search'])
    parser.add_argument('--project', required=True, help='Project directory')
    parser.add_argument('--template', help='Template directory for setup')
    parser.add_argument('--tags', help='Comma-separated tags for search')
    
    args = parser.parse_args()
    
    if args.command == 'setup':
        manager = AIDevSystemManager(Path('.'))
        manager.setup_new_project(Path(args.template), args.project)
    
    elif args.command == 'migrate':
        manager = AIDevSystemManager(Path('.'))
        manager.migrate_existing_project(Path(args.project))
    
    elif args.command == 'monitor':
        orchestrator = DevelopmentOrchestrator(Path(args.project))
        print("🔍 Monitoring development progress...")
        # Start monitoring loop
    
    elif args.command == 'search':
        hashtag_manager = HashtagManager(Path(args.project))
