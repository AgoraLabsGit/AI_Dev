// ✅ Standard Interactive Component
interface FormComponentProps {{
  onSubmit: (data: FormData) => void;
  loading?: boolean;
  error?: string;
}}

export function FormComponent({{ onSubmit, loading, error }}: FormComponentProps) {{
  const [formData, setFormData] = useState<FormData>({{}})
  
  const handleSubmit = (e: FormEvent) => {{
    e.preventDefault()
    onSubmit(formData)
  }}
  
  return (
    <form onSubmit={{handleSubmit}}>
      {{/* Form elements */}}
      {{error && <div className="error">{{error}}</div>}}
      <button disabled={{loading}}>
        {{loading ? 'Loading...' : 'Submit'}}
      </button>
    </form>
  )
}}
```

### Display Component Pattern
```typescript
// ✅ Standard Display Component
interface DataDisplayProps {{
  data: DataItem[];
  loading?: boolean;
  error?: string;
}}

export function DataDisplay({{ data, loading, error }}: DataDisplayProps) {{
  if (loading) return <div>Loading...</div>
  if (error) return <div>Error: {{error}}</div>
  if (!data.length) return <div>No data available</div>
  
  return (
    <div className="data-display">
      {{data.map(item => (
        <div key={{item.id}} className="data-item">
          {{/* Display item */}}
        </div>
      ))}}
    </div>
  )
}}
```

