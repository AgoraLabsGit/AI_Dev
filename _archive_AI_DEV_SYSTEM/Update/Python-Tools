class AIDevSystemManager:
    """Main orchestrator for AI-First Development System"""
    
    def __init__(self, project_root: Path):
        self.project_root = Path(project_root)
        self.config = self.load_project_config()
        self.tag_index = {}
        self.pattern_library = {}
        
    def setup_new_project(self, template_path: Path, project_name: str):
        """Initialize new project from template"""
        print(f"🚀 Setting up new AI-first project: {project_name}")
        
        # Copy template structure
        project_path = self.project_root / project_name
        shutil.copytree(template_path, project_path)
        
        # Customize PROJECT-CONFIG.md
        self.customize_project_config(project_path, project_name)
        
        # Initialize logging system
        self.initialize_logging_system(project_path)
        
        # Set up file watching
        self.setup_file_watcher(project_path)
        
        print(f"✅ Project {project_name} ready for AI development")
        return project_path
    
    def migrate_existing_project(self, existing_path: Path):
        """Migrate existing project to AI-first structure"""
        print("🔄 Starting project migration...")
        
        # Audit existing project
        audit_results = self.audit_existing_project(existing_path)
        
        # Extract patterns and documentation
        patterns = self.extract_code_patterns(existing_path)
        docs = self.extract_documentation(existing_path)
        
        # Create AI-first structure
        self.create_tier_structure(existing_path, patterns, docs)
        
        # Generate hashtag index from existing code
        self.generate_initial_hashtags(existing_path, patterns)
        
        print("✅ Migration complete - project ready for AI collaboration")
    
    def audit_existing_project(self, project_path: Path) -> Dict:
        """Analyze existing project structure and patterns"""
        audit = {
            'files': [],
            'patterns': {},
            'documentation': [],
            'dependencies': {},
            'tech_stack': {}
        }
        
        # Scan file structure
        for file_path in project_path.rglob('*'):
            if file_path.is_file() and not self.should_ignore_file(file_path):
                audit['files'].append({
                    'path': str(file_path.relative_to(project_path)),
                    'type': self.classify_file_type(file_path),
                    'size': file_path.stat().st_size,
                    'tags': self.suggest_file_tags(file_path)
                })
        
        # Extract code patterns
        audit['patterns'] = self.extract_code_patterns(project_path)
        
        # Find documentation
        audit['documentation'] = self.find_documentation_files(project_path)
        
        return audit
    
    def extract_code_patterns(self, project_path: Path) -> Dict:
        """Extract reusable patterns from existing codebase"""
        patterns = {
            'components': [],
            'api_endpoints': [],
            'database_queries': [],
            'auth_flows': [],
            'integrations': [],
            'utilities': []
        }
        
        # Find React components
        for tsx_file in project_path.rglob('*.tsx'):
            if self.is_component_file(tsx_file):
                component_info = self.analyze_component(tsx_file)
                patterns['components'].append(component_info)
        
        # Find API endpoints
        for api_file in project_path.rglob('**/api/**/*.ts'):
            endpoint_info = self.analyze_api_endpoint(api_file)
            patterns['api_endpoints'].append(endpoint_info)
        
        # Find database patterns
        for db_file in project_path.rglob('**/*{model,schema,query}*.ts'):
            db_info = self.analyze_database_pattern(db_file)
            patterns['database_queries'].append(db_info)
        
        return patterns
    
    def generate_tier_documentation(self, patterns: Dict, config: ProjectConfig):
        """Generate tier documentation from extracted patterns"""
        
        # Generate Tier 1 (Quick Implementation)
        tier1_docs = {
            'ARCHITECTURE-QUICK.md': self.generate_architecture_quick(patterns, config),
            'BACKEND-QUICK.md': self.generate_backend_quick(patterns, config),
            'FRONTEND-QUICK.md': self.generate_frontend_quick(patterns, config)
        }
        
        # Generate Tier 2 (Living Examples) 
        tier2_examples = self.generate_living_examples(patterns)
        
        # Generate Tier 3 (Comprehensive Masters)
        tier3_masters = self.generate_comprehensive_masters(patterns, config)
        
        return tier1_docs, tier2_examples, tier3_masters

class HashtagManager:
    """Manages hashtag system for development intelligence"""
    
    def __init__(self, project_root: Path):
        self.project_root = project_root
        self.tag_index = self.load_tag_index()
        
    def suggest_tags(self, file_path: Path, content: str) -> Set[str]:
        """AI-powered tag suggestion based on file content and patterns"""
        tags = set()
        
        # File-based tags
        tags.update(self.get_file_type_tags(file_path))
        
        # Content-based tags
        tags.update(self.analyze_content_for_tags(content))
        
        # Pattern-based tags
        tags.update(self.detect_pattern_tags(content))
        
        return tags
    
    def get_file_type_tags(self, file_path: Path) -> Set[str]:
        """Generate tags based on file type and location"""
        tags = set()
        
        path_str = str(file_path)
        
        # Directory-based tags
        if '/components/' in path_str:
            tags.add('#frontend-components')
        if '/api/' in path_str:
            tags.add('#backend-api')
        if '/pages/' in path_str:
            tags.add('#frontend-pages')
        if '/lib/' in path_str or '/utils/' in path_str:
            tags.add('#utilities')
        
        # File extension tags
        if file_path.suffix in ['.tsx', '.jsx']:
            tags.add('#react-components')
        elif file_path.suffix in ['.ts', '.js'] and '/api/' in path_str:
            tags.add('#api-endpoints')
        elif 'schema' in file_path.name or 'model' in file_path.name:
            tags.add('#database-schema')
        
        return tags
    
    def analyze_content_for_tags(self, content: str) -> Set[str]:
        """Analyze file content to suggest domain and feature tags"""
        tags = set()
        
        # Security patterns
        if any(term in content.lower() for term in ['auth', 'login', 'password', 'jwt', 'session']):
            tags.add('#user-auth')
        if any(term in content.lower() for term in ['encrypt', 'hash', 'secure', 'validate']):
            tags.add('#security')
        
        # Payment patterns
        if any(term in content.lower() for term in ['stripe', 'payment', 'checkout', 'billing']):
            tags.add('#payment-flow')
        
        # Multi-tenant patterns
        if any(term in content.lower() for term in ['tenant', 'organization', 'workspace']):
            tags.add('#multi-tenant')
        
        # Database patterns
        if any(term in content.lower() for term in ['prisma', 'query', 'where', 'findMany']):
            tags.add('#database-operations')
        
        return tags
    
    def search_by_tags(self, search_tags: Set[str]) -> List[Dict]:
        """Search development history by hashtags"""
        results = []
        
        # Search logs for matching tags
        logs_dir = self.project_root / 'logs'
        for log_file in logs_dir.glob('*.md'):
            matches = self.search_file_for_tags(log_file, search_tags)
            results.extend(matches)
        
        return sorted(results, key=lambda x: x['timestamp'], reverse=True)

class DevelopmentOrchestrator:
    """Orchestrates AI collaboration workflow"""
    
    def __init__(self, project_root: Path):
        self.project_root = project_root
        self.current_task = None
        self.ai_state = {'cursor': 'idle', 'copilot': 'idle'}
        
    def start_development_cycle(self, task_description: str):
